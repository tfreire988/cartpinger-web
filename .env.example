# CartPinger — variables de entorno
# En Vercel: Settings → Environment Variables
# En local: copia a .env (nunca comitas .env)

# 1. Resend API Key — https://resend.com (gratis, sin tarjeta)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2. Resend Audience ID — Resend → Audiences → Create → copiar ID
RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 3. Tu email para recibir avisos de nuevas suscripciones
NOTIFY_EMAIL=info@cartpinger.com
